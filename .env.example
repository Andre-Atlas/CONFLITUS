# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="YOUR_APP_URL"

# Mapbox Token needed for 3D Globe visualization
VITE_MAPBOX_TOKEN="YOUR_MAPBOX_TOKEN"

# ACLED — Conflict Data API
ACLED_EMAIL="YOUR_ACLED_EMAIL"
ACLED_KEY="YOUR_ACLED_KEY"

# UCDP — Uppsala Conflict Data Program
UCDP_TOKEN="YOUR_UCDP_TOKEN"

# OpenRouteService — Route Directions
ORS_TOKEN="YOUR_ORS_TOKEN"

# Duffel — Air Transport Routes
DUFFEL_TOKEN="YOUR_DUFFEL_TOKEN"
